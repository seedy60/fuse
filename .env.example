# Fuse Configuration

# Port the server listens on
FUSE_PORT=3000

# Maximum file size in bytes (default: 500MB)
FUSE_MAX_FILE_SIZE=524288000

# Base URL used for generating download links (no trailing slash)
FUSE_BASE_URL=http://localhost:3000

# SSL/TLS - set both to enable HTTPS
FUSE_SSL_CERT=
FUSE_SSL_KEY=

# Upload directory (relative or absolute path)
FUSE_UPLOAD_DIR=./uploads

# Cleanup interval in minutes (how often expired files are purged)
FUSE_CLEANUP_INTERVAL=10

# Require first-download claim code by default
FUSE_REQUIRE_CLAIM_CODE=true

# Server-side pepper for owner token hashing (set a long random value)
FUSE_TOKEN_PEPPER=change-me-to-a-long-random-secret

# Claim code brute-force protection
FUSE_CLAIM_MAX_ATTEMPTS=5
FUSE_CLAIM_WINDOW_MINUTES=15
FUSE_CLAIM_BLOCK_MINUTES=30
